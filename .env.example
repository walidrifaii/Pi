PORT=5000
MONGODB_URI=mongodb://localhost:27017/whatsapp_saas
JWT_SECRET=your_super_secret_jwt_key_change_in_production
REDIS_URL=redis://localhost:6379
# whatsapp-web.js LocalAuth session folders live here. On EasyPanel/Docker, mount a persistent
# volume to this path (e.g. mount named volume at /app/sessions and set SESSIONS_DIR=/app/sessions).
# Do not rely on /tmp — it is cleared on container restart.
SESSIONS_DIR=./sessions
MIN_DELAY_MS=20000
MAX_DELAY_MS=30000
WA_INIT_TIMEOUT_MS=180000
WA_INIT_MAX_RETRIES=2
WA_INIT_RETRY_BASE_DELAY_MS=5000
WA_INIT_RETRY_MAX_DELAY_MS=30000
CORS_ORIGINS=https://whatsap-sigma.vercel.app
NODE_ENV=development
QR_SHARE_TOKEN=put_a_long_random_string_here

# Laravel (or any trusted server) calling this API without a browser JWT:
# Generate a long random string, set the same value in Laravel .env as LARAVEL_INTEGRATION_SECRET.
# X-Integration-User-Id must be the Node `users.id` (owner of the WhatsApp client / balance).
LARAVEL_INTEGRATION_SECRET=

# SMTP (optional, used for balance exhausted email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
